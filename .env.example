# Choose provider: openai or hackclub
FILEGEN_AI_PROVIDER=openai

# OpenAI configuration (default / easiest setup)
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o-mini
# OPENAI_IMAGE_GENERATION_MODEL=gpt-image-1
# OPENAI_IMAGE_EDIT_MODELS=gpt-image-1

# HackClub configuration (optional fallback)
# HACKCLUB_API_KEY=your_hackclub_api_key_here
# HACKCLUB_BASE_URL=https://ai.hackclub.com/proxy/v1
# HACKCLUB_CHAT_MODEL=qwen/qwen3-32b
# HACKCLUB_VISION_MODEL=your_hackclub_vision_model
# HACKCLUB_IMAGE_GENERATION_MODEL=your_hackclub_image_model
# HACKCLUB_IMAGE_EDIT_MODELS=your_hackclub_edit_model
